#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

bash "$ROOT/scripts/check-rust-file-size.sh" "$ROOT/bitloops"
cargo fmt --all --manifest-path "$ROOT/bitloops/Cargo.toml"
cargo clippy --manifest-path "$ROOT/bitloops/Cargo.toml" --all-targets --all-features -- -D warnings
