#!/bin/sh
# Bitloops git hooks
# Pre-push hook: push session logs alongside user's push
# $1 is the remote name (e.g., "origin")
bitloops hooks git pre-push "$1" || true
# Chain: run pre-existing hook
_bitloops_hook_dir="$(dirname "$0")"
if [ -x "$_bitloops_hook_dir/pre-push.pre-bitloops" ]; then
"$_bitloops_hook_dir/pre-push.pre-bitloops" "$@"
fi
