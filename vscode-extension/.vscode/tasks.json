{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "bitloops-extension: compile",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "compile"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": "$tsc"
    },
    {
      "label": "bitloops-extension: watch",
      "type": "shell",
      "command": "pnpm",
      "args": [
        "watch"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": "$tsc-watch"
    }
  ]
}
