{
  "name": "bitloops",
  "displayName": "Bitloops",
  "description": "Bitloops DevQL overviews and artefact search for VS Code Extesnsion-compatible editors.",
  "version": "0.20.0",
  "publisher": "Bitloops",
  "license": "Apache-2.0",
  "homepage": "https://bitloops.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitloops/bitloops.git"
  },
  "icon": "media/bitloops-logo.png",
  "engines": {
    "vscode": "^1.89.0"
  },
  "categories": [
    "Other"
  ],
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "pnpm compile",
    "pretest": "pnpm compile",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.17",
    "@types/vscode": "1.89.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.1.0",
    "typescript": "^5.6.3"
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bitloopsSidebar",
          "title": "Bitloops",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "bitloopsSidebar": [
        {
          "id": "bitloopsSearchView",
          "name": "Search",
          "contextualTitle": "Bitloops",
          "icon": "media/icon.svg",
          "type": "webview"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "bitloopsSearchView",
        "contents": "Search DevQL artefacts in the active workspace folder.\n[Search artefacts](command:bitloops.searchArtefacts)"
      }
    ],
    "commands": [
      {
        "command": "bitloops.searchArtefacts",
        "title": "Bitloops: Search Artefacts"
      },
      {
        "command": "bitloops.refreshActiveFileOverview",
        "title": "Bitloops: Refresh Active File Overview"
      },
      {
        "command": "bitloops.openSearchResult",
        "title": "Bitloops: Open Search Result"
      },
      {
        "command": "bitloops.showOverviewDetails",
        "title": "Bitloops: Show Overview Details"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "bitloops.searchArtefacts",
          "when": "view == bitloopsSearchView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Bitloops",
      "properties": {
        "bitloops.cliPath": {
          "type": "string",
          "default": "bitloops",
          "description": "Path to the Bitloops CLI binary."
        },
        "bitloops.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Refresh Bitloops CodeLens when the active editor, saved document, or workspace folders change."
        },
        "bitloops.searchResultLimit": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "description": "Maximum number of artefacts to show in the Bitloops search sidebar."
        },
        "bitloops.activeFileArtefactLimit": {
          "type": "number",
          "default": 200,
          "minimum": 1,
          "description": "Maximum number of active-file artefacts to request when building CodeLens."
        }
      }
    }
  }
}
